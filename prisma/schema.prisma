generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectType {
  RESTAURANT
  OFFICE
  RETAIL
  HOTEL
  WAREHOUSE
  RESIDENTIAL
}

enum PunchItemStatus {
  DRAFT
  OPEN
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  phone         String?
  createdAt     DateTime  @default(now())
  
  companies        Company[]
  trades           Trade[]
  subTrades        SubTrade[]
  projects         Project[]
  punchItems       PunchItem[]
  statusHistory    PunchItemStatusHistory[]
  projectAdmins    ProjectAdmin[]
}

model Company {
  id          String   @id @default(cuid())
  userId      String
  name        String
  address     String?
  createdAt   DateTime @default(now())
  
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
}

model ProjectType {
  id      String       @id @default(cuid())
  name    ProjectType  @unique
  projects Project[]
}

model Project {
  id              String        @id @default(cuid())
  userId          String
  companyId       String
  projectTypeId   String
  name            String
  clientName      String?
  clientAddress   String?
  projectNumber   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectType  ProjectType      @relation(fields: [projectTypeId], references: [id])
  areas        Area[]
  punchItems   PunchItem[]
  admins       ProjectAdmin[]
}

model Trade {
  id      String   @id @default(cuid())
  userId  String
  name    String
  createdAt DateTime @default(now())
  
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  subTrades SubTrade[]
  punchItems PunchItem[]
}

model SubTrade {
  id        String  @id @default(cuid())
  tradeId   String
  userId    String
  name      String
  
  trade     Trade       @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  punchItems PunchItem[]
}

model Area {
  id        String  @id @default(cuid())
  projectId String
  name      String
  isCustom  Boolean @default(false)
  
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  punchItems PunchItem[]
}

model PunchItem {
  id          String           @id @default(cuid())
  projectId   String
  tradeId     String?
  subTradeId  String?
  areaId      String?
  description String?
  status      PunchItemStatus  @default(DRAFT)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  project      Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  trade        Trade?                   @relation(fields: [tradeId], references: [id])
  subTrade     SubTrade?                @relation(fields: [subTradeId], references: [id])
  area         Area?                    @relation(fields: [areaId], references: [id])
  photos       PunchItemPhoto[]
  statusHistory PunchItemStatusHistory[]
  user         User                     @relation(fields: [userId], references: [id])
  userId       String
}

model PunchItemPhoto {
  id          String    @id @default(cuid())
  punchItemId String
  filename    String
  originalName String
  order       Int       @default(1)
  uploadedAt  DateTime  @default(now())
  
  punchItem PunchItem @relation(fields: [punchItemId], references: [id], onDelete: Cascade)
}

model PunchItemStatusHistory {
  id          String           @id @default(cuid())
  punchItemId String
  status      PunchItemStatus
  note        String?
  userId      String
  createdAt   DateTime         @default(now())
  
  punchItem PunchItem @relation(fields: [punchItemId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])
}

model ProjectAdmin {
  id              String  @id @default(cuid())
  projectId       String
  userId          String
  isPrimaryAdmin  Boolean @default(false)
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}